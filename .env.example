# ================================================================
# LambatRegistryBot - Environment Configuration Template
# ================================================================
# Copy this file to .env and fill in your values
# Required variables MUST be set or the bot will not start
# ================================================================

# ================================================================
# CORE SETTINGS (REQUIRED)
# ================================================================

# Discord Bot Token
# Get this from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# PostgreSQL Database Connection URL
# Format: postgresql://username:password@localhost:5432/database_name
DATABASE_URL=postgresql://user:password@localhost:5432/pavia_registry

# Bot Owner Discord ID
# This user has full access and can execute owner-only commands
OWNER_ID=123456789

# ================================================================
# ROLE CONFIGURATION (REQUIRED)
# ================================================================

# Full Access Role IDs (comma-separated)
# Users with these roles can add/update/remove citizens
# Example: 111111111,222222222
FULL_ACCESS_ROLE_IDS=111111111,222222222

# Citizen Role IDs (comma-separated)
# Roles to assign when someone becomes a citizen
# At least ONE role ID is required
CITIZEN_ROLE_IDS=333333333,444444444

# View Access Role ID
# Users with this role can view citizen info and reports
VIEW_ACCESS_ROLE_ID=555555555

# Guest Role ID
# Assigned to new users who haven't been registered
GUEST_ROLE_ID=666666666

# Settler Role ID
# Optional role assigned to all citizens
SETTLER_ROLE_ID=777777777

# ================================================================
# CHANNEL CONFIGURATION (OPTIONAL)
# ================================================================

# Council Channel ID
# Channel where admin commands are executed
COUNCIL_CHANNEL_ID=888888888

# Registry Channel ID
# Channel for citizen registry announcements
REGISTRY_CHANNEL_ID=999999999

# Audit Log Channel ID
# Channel for audit logs and critical events
AUDIT_LOG_CHANNEL_ID=1010101010

# ================================================================
# NETWORK & PERFORMANCE SETTINGS (OPTIONAL)
# ================================================================
# All values below are optional and have sensible defaults
# Only set these if you need to tune performance

# HTTP Client Total Timeout (seconds)
# Default: 5
AIOHTTP_TOTAL_TIMEOUT=5

# HTTP Client Connect Timeout (seconds)
# Default: 3
# Must be less than AIOHTTP_TOTAL_TIMEOUT
AIOHTTP_CONNECT_TIMEOUT=3

# Command Semaphore Limit
# Controls how many commands can run concurrently
# Default: 3
COMMAND_SEMAPHORE_LIMIT=3

# CivInfo API Rate Limit
# Maximum concurrent API calls to CivInfo
# Default: 10
CIVINFO_API_RATE_LIMIT=10

# ================================================================
# STORAGE SETTINGS (OPTIONAL)
# ================================================================

# Backup Directory
# Where database backups are stored
# Default: backups
BACKUP_DIR=backups

# Proxy URL (OPTIONAL)
# If you need to route Discord API through a proxy
# Leave empty if not using a proxy
PROXY_URL=

# ================================================================
# NOTES
# ================================================================
# 1. Required variables that are missing will cause the bot to
#    exit with a clear error message on startup
#
# 2. All role IDs and channel IDs should be numeric Discord IDs
#
# 3. CITIZEN_ROLE_IDS must have at least one role ID
#
# 4. Keep this file secure - it contains sensitive information
#    Add .env to your .gitignore to avoid committing it
#
# 5. For comma-separated values, do not include spaces:
#    CORRECT:   FULL_ACCESS_ROLE_IDS=111111111,222222222
#    WRONG:     FULL_ACCESS_ROLE_IDS=111111111, 222222222
# ================================================================
